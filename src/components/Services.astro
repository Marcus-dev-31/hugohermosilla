---

<section class="services" id="servicios">
  <div class="section-label">Servicios</div>

  <div class="services-grid">

    <div class="service-card">
      <div class="service-num">01 — DJ & Sets</div>
      <div class="service-icon">♫</div>
      <h2 class="service-title">
        Music &<br><em>Performance</em>
      </h2>
      <p class="service-desc">
        Sets personalizados para eventos, fiestas privadas y producción de mezclas.
        Techno, house, experimental — el soundtrack que tu noche necesita.
      </p>
      <div class="service-tags">
        <span class="tag">Sets en vivo</span>
        <span class="tag">Eventos privados</span>
        <span class="tag">Mezclas a medida</span>
        <span class="tag">SoundCloud / Mixcloud</span>
      </div>
    </div>

    <div class="service-card">
      <div class="service-num">02 — Video</div>
      <div class="service-icon">▶</div>
      <h2 class="service-title">
        Edición &<br><em>Motion</em>
      </h2>
      <p class="service-desc">
        Edición profesional de video con ojo musical. Reels de Instagram,
        aftermovies, contenido para marcas y clips que generan engagement real.
      </p>
      <div class="service-tags">
        <span class="tag">Reels Instagram</span>
        <span class="tag">Aftermovies</span>
        <span class="tag">Contenido marcas</span>
        <span class="tag">Motion graphics</span>
      </div>
    </div>

  </div>
</section>

<style>
  /* ── BASE (mobile) ── */
  .services {
    background: var(--black-2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 4rem 1.5rem;
  }

  .section-label {
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .section-label::after {
    content: '';
    flex: 1;
    max-width: 4rem;
    height: 1px;
    background: var(--red-dim);
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 2rem;
  }

  .service-card {
    padding: 2.5rem 1.5rem;
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s;
  }

  .service-card:hover { border-color: var(--border-red); }

  .service-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 20% 80%, var(--red-glow), transparent 70%);
    opacity: 0;
    transition: opacity 0.5s;
  }

  .service-card:hover::before { opacity: 1; }

  .service-num {
    font-family: var(--bebas);
    font-size: 0.9rem;
    letter-spacing: 0.2em;
    color: var(--red);
    margin-bottom: 2rem;
  }

  .service-title {
    font-family: var(--bebas);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 0.9;
    letter-spacing: 0.02em;
    color: var(--white);
    margin-bottom: 1.5rem;
  }

  .service-title em {
    font-family: var(--serif);
    font-style: italic;
    color: var(--red);
    font-size: 0.7em;
  }

  .service-desc {
    font-size: 0.72rem;
    color: var(--white-dim);
    line-height: 1.8;
    max-width: 28rem;
    margin-bottom: 2.5rem;
  }

  .service-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--white-dim);
    border: 1px solid var(--border);
    padding: 0.3rem 0.7rem;
    transition: color 0.2s, border-color 0.2s;
  }

  .service-card:hover .tag {
    border-color: var(--border-red);
    color: var(--white);
  }

  .service-icon {
    position: absolute;
    right: 3rem;
    top: 3.5rem;
    font-family: var(--bebas);
    font-size: 7rem;
    color: rgba(240, 237, 232, 0.04);
    line-height: 1;
    pointer-events: none;
  }

  /* ── DESKTOP ── */
  @media (min-width: 769px) {
    .services {
      padding: 7rem 3rem;
    }

    .services-grid {
      grid-template-columns: 1fr 1fr;
      gap: 0;
      margin-top: 4rem;
    }

    .service-card {
      padding: 3.5rem;
    }
  }
</style>