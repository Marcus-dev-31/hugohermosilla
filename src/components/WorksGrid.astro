---
import { getCollection } from "astro:content";

const works = await getCollection("works");
const sorted = works.sort((a, b) => a.data.order - b.data.order).slice(0, 4);
---

<section id="trabajos">
  <div class="works-header reveal">
    <div>
      <div class="section-label">Trabajos recientes</div>
      <h2 class="works-title">
        <span>Lo que</span>
        HAGO
      </h2>
    </div>
    <a href="#contacto" class="see-all">Ver todo el trabajo →</a>
  </div>

  <div class="works-grid reveal reveal-delay-1">
    {
      sorted.map((work, index) => (
        <button
          class={`work-item w${index + 1}`}
          data-vimeo-id={work.data.vimeoId || ""}
          data-soundcloud-url={work.data.soundcloudUrl || ""}
          data-title={work.data.title}
          aria-label={`Ver ${work.data.title}`}
        >
          <div class="work-inner">
            <div class="work-thumb">
              <div class="work-thumb-bg" />
              {index === 0 && <div class="waveform" id="waveform" />}
              {(work.data.vimeoId || work.data.soundcloudUrl) && (
                <div class="play-icon" aria-hidden="true">
                  <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                    <circle
                      cx="24"
                      cy="24"
                      r="23"
                      stroke="#F0EDE8"
                      stroke-width="1"
                      opacity="0.4"
                    />
                    <path d="M20 16l16 8-16 8V16z" fill="#F0EDE8" />
                  </svg>
                </div>
              )}
            </div>
            <div class="work-meta">
              <div class="work-meta-left">
                <div class="work-cat">{work.data.category}</div>
                <div class="work-name">{work.data.title}</div>
                <div class="work-year">
                  {work.data.year}
                  {work.data.client ? ` — ${work.data.client}` : ""}
                </div>
              </div>
              <div class="work-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" stroke-width="2">
                  <path d="M7 17L17 7M7 7h10v10" />
                </svg>
              </div>
            </div>
          </div>
        </button>
      ))
    }
  </div>
</section>

<!-- MODAL -->
<div
  class="modal"
  id="worksModal"
  role="dialog"
  aria-modal="true"
  aria-label="Reproductor de trabajo"
  aria-hidden="true"
>
  <div class="modal-backdrop" id="modalBackdrop"></div>
  <div class="modal-container">
    <button class="modal-close" id="modalClose" aria-label="Cerrar">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <line x1="1" y1="1" x2="23" y2="23" stroke="#F0EDE8" stroke-width="2"
        ></line>
        <line x1="23" y1="1" x2="1" y2="23" stroke="#F0EDE8" stroke-width="2"
        ></line>
      </svg>
    </button>
    <div class="modal-content" id="modalContent"></div>
  </div>
</div>

<style>
  /* ── BASE (mobile) ── */
  .section-label {
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .section-label::after {
    content: "";
    flex: 1;
    max-width: 4rem;
    height: 1px;
    background: var(--red-dim);
  }

  .works-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .works-title {
    font-family: var(--bebas);
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.9;
    letter-spacing: 0.02em;
  }

  .works-title span {
    display: block;
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.35em;
    color: var(--white-dim);
    letter-spacing: 0.05em;
  }

  .see-all {
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--white-dim);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.3rem;
    transition:
      color 0.2s,
      border-color 0.2s;
    white-space: nowrap;
  }

  .see-all:hover {
    color: var(--red);
    border-color: var(--red);
  }

  .works-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .work-item {
    position: relative;
    overflow: hidden;
    background: var(--black-3);
    cursor: pointer;
    border: none;
    padding: 0;
    text-align: left;
  }

  .work-item:nth-child(1) {
    aspect-ratio: 16 / 9;
  }

  .work-inner {
    width: 100%;
    height: 100%;
    min-height: 200px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
    position: relative;
  }

  .work-thumb {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .work-thumb::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(8, 8, 8, 0.92) 0%,
      rgba(8, 8, 8, 0.2) 60%,
      transparent 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  .work-thumb-bg {
    position: absolute;
    inset: 0;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .work-item:hover .work-thumb-bg {
    transform: scale(1.06);
  }

  .w1 .work-thumb-bg {
    background: linear-gradient(135deg, #1a0a05 0%, #3d1408 40%, #0a0a0a 100%);
  }
  .w2 .work-thumb-bg {
    background: linear-gradient(135deg, #05101a 0%, #0d2a3d 40%, #0a0a0a 100%);
  }
  .w3 .work-thumb-bg {
    background: linear-gradient(135deg, #0a1a05 0%, #1a3d0d 40%, #0a0a0a 100%);
  }
  .w4 .work-thumb-bg {
    background: linear-gradient(135deg, #1a0514 0%, #3d0d2a 40%, #0a0a0a 100%);
  }

  .waveform {
    position: absolute;
    bottom: 35%;
    left: 5%;
    right: 5%;
    height: 60px;
    display: flex;
    align-items: center;
    gap: 2px;
    z-index: 2;
  }

  .wave-bar {
    flex: 1;
    background: var(--red);
    opacity: 0.5;
    border-radius: 1px;
    animation: wave-anim 1.2s ease-in-out infinite alternate;
  }

  @keyframes wave-anim {
    from {
      transform: scaleY(var(--min));
    }
    to {
      transform: scaleY(var(--max));
    }
  }

  .play-icon {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .work-item:hover .play-icon {
    opacity: 1;
  }

  .work-meta {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }

  .work-cat {
    font-size: 0.58rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 0.4rem;
  }

  .work-name {
    font-family: var(--bebas);
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    letter-spacing: 0.04em;
    color: var(--white);
    line-height: 1;
  }

  .work-year {
    font-size: 0.6rem;
    color: var(--white-dim);
    letter-spacing: 0.12em;
  }

  .work-arrow {
    width: 36px;
    height: 36px;
    border: 1px solid rgba(240, 237, 232, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity 0.3s,
      transform 0.3s,
      background 0.2s;
  }

  .work-item:hover .work-arrow {
    opacity: 1;
    transform: translateY(0);
    background: var(--red);
    border-color: var(--red);
  }

  .work-arrow svg {
    width: 12px;
    height: 12px;
    stroke: var(--white);
    fill: none;
  }

  /* ── MODAL ── */
  .modal {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .modal.open {
    opacity: 1;
    pointer-events: all;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(8, 8, 8, 0.95);
  }

  .modal-container {
    position: relative;
    z-index: 1;
    width: 90vw;
    max-width: 1000px;
  }

  .modal-close {
    position: absolute;
    top: -3rem;
    right: 0;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    z-index: 2;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .modal-close:hover {
    opacity: 1;
  }

  .modal-content {
    width: 100%;
    position: relative;
    padding-bottom: 56.25%; /* 16:9 */
    height: 0;
  }

  .modal-content iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* ── TABLET ── */
  @media (min-width: 481px) and (max-width: 768px) {
    .works-grid {
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }

    .work-item:nth-child(1),
    .work-item:nth-child(2),
    .work-item:nth-child(3),
    .work-item:nth-child(4) {
      grid-column: span 1;
    }

    .work-item:nth-child(1) .work-inner,
    .work-item:nth-child(2) .work-inner,
    .work-item:nth-child(3) .work-inner,
    .work-item:nth-child(4) .work-inner {
      min-height: 220px;
    }
  }

  /* ── DESKTOP ── */
  @media (min-width: 769px) {
    .works-header {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 3rem;
    }

    .see-all {
      margin-bottom: 0.5rem;
    }

    .works-grid {
      grid-template-columns: repeat(12, 1fr);
      grid-template-rows: auto auto;
      gap: 2px;
    }

    .work-item:nth-child(1) {
      aspect-ratio: unset;
      grid-column: span 7;
      grid-row: span 2;
    }
    .work-item:nth-child(2) {
      grid-column: span 5;
    }
    .work-item:nth-child(3) {
      grid-column: span 3;
    }
    .work-item:nth-child(4) {
      grid-column: span 2;
    }

    .work-item:nth-child(1) .work-inner {
      min-height: 420px;
    }
    .work-item:nth-child(2) .work-inner {
      min-height: 210px;
    }

    .modal-container {
      width: 80vw;
    }
  }
</style>

<script>
  // ── WAVEFORM ──
  const waveformEl = document.getElementById("waveform");
  if (waveformEl) {
    for (let i = 0; i < 60; i++) {
      const bar = document.createElement("div");
      bar.className = "wave-bar";
      const minH = 0.1 + Math.random() * 0.3;
      const maxH = minH + 0.3 + Math.random() * 0.5;
      bar.style.setProperty("--min", String(minH));
      bar.style.setProperty("--max", String(maxH));
      bar.style.animationDelay = Math.random() * 1.2 + "s";
      bar.style.animationDuration = 0.6 + Math.random() * 0.8 + "s";
      waveformEl.appendChild(bar);
    }
  }

  // ── SCROLL REVEAL ──
  const reveals = document.querySelectorAll(".reveal");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add("visible");
      });
    },
    { threshold: 0.12 },
  );
  reveals.forEach((el) => observer.observe(el));

  // ── MODAL ──
  const modal = document.getElementById("worksModal") as HTMLElement;
  const backdrop = document.getElementById("modalBackdrop") as HTMLElement;
  const closeBtn = document.getElementById("modalClose") as HTMLElement;
  const content = document.getElementById("modalContent") as HTMLElement;
  const workItems = document.querySelectorAll(".work-item");
  const mainContent = document.querySelector("main") as HTMLElement;

  function openModal(vimeoId: string) {
    content.innerHTML = `
      <iframe
        style="position:absolute;inset:0;width:100%;height:100%;border:none;display:block;"
        src="https://player.vimeo.com/video/${vimeoId}?autoplay=1&color=E8341A&title=0&byline=0&portrait=0"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen>
      </iframe>
    `;
    modal.classList.add("open");
    modal.setAttribute("aria-hidden", "false");
    if (mainContent) mainContent.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "hidden";
    closeBtn.focus();
  }

  function closeModal() {
    content.innerHTML = "";
    modal.classList.remove("open");
    modal.setAttribute("aria-hidden", "true");
    if (mainContent) mainContent.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "";
  }

  workItems.forEach((item) => {
    item.addEventListener("click", () => {
      const vimeoId = (item as HTMLElement).dataset.vimeoId;
      if (vimeoId) openModal(vimeoId);
    });
  });

  backdrop.addEventListener("click", closeModal);
  closeBtn.addEventListener("click", closeModal);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>
