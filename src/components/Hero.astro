---
---

<section class="hero">
  <div class="hero-divider"></div>

  <div class="hero-side left">
    <div class="hero-bg-text" aria-hidden="true">DJ</div>
    <div class="hero-tag">Sets / Eventos / Club</div>
    <h1 class="hero-title">
      <span class="glitch" data-text="HUGO">HUGO</span>
    </h1>
    <p class="hero-sub">
      Más de 8 años construyendo pisos de baile.<br>
      Desde techno crudo hasta sets de madrugada —
      cada noche tiene su propia frecuencia.
    </p>
    <a href="#trabajos" class="hero-cta">
      Escuchar sets
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>

  <div class="hero-side right">
    <div class="hero-bg-text" aria-hidden="true">VID</div>
    <div class="hero-tag">Edit / Motion / Reels</div>
    <h2 class="hero-title">
      <span class="glitch" data-text="EDIT">EDIT</span>
    </h2>
    <p class="hero-sub">
      Edición de video con sensibilidad musical.<br>
      Reels, aftermovies, contenido para marcas —
      el corte que hace sentir cada segundo.
    </p>
    <a href="#trabajos" class="hero-cta">
      Ver trabajos
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>

  <div class="scroll-hint" aria-hidden="true">
    <div class="scroll-line"></div>
    scroll
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    overflow: hidden;
  }

  .hero-divider {
    position: absolute;
    left: 50%; top: 0; bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, transparent, var(--red) 30%, var(--red) 70%, transparent);
    transform: translateX(-50%);
    z-index: 10;
  }

  .hero-divider::before {
    content: '';
    position: absolute;
    left: 50%; top: 50%;
    transform: translate(-50%, -50%);
    width: 8px; height: 8px;
    background: var(--red);
    border-radius: 50%;
    box-shadow: 0 0 20px var(--red), 0 0 40px var(--red-dim);
  }

  .hero-side {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 8rem 4rem 5rem;
    position: relative;
    overflow: hidden;
    transition: background 0.5s;
  }

  .hero-side:hover { background: rgba(232, 52, 26, 0.03); }
  .hero-side.left  { padding-right: 5rem; align-items: flex-end; text-align: right; }
  .hero-side.right { padding-left: 5rem; }

  .hero-tag {
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 1.2rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .hero-side.left .hero-tag { justify-content: flex-end; }

  .hero-tag::before,
  .hero-tag::after {
    content: '';
    display: block;
    width: 2rem; height: 1px;
    background: var(--red);
  }

  .hero-side.left .hero-tag::before  { display: none; }
  .hero-side.right .hero-tag::after  { display: none; }

  .hero-title {
    font-family: var(--bebas);
    font-size: clamp(5rem, 12vw, 10rem);
    line-height: 0.88;
    letter-spacing: -0.02em;
    color: var(--white);
    position: relative;
  }

  .hero-title .glitch {
    position: relative;
    display: inline-block;
  }

  .hero-title .glitch::before,
  .hero-title .glitch::after {
    content: attr(data-text);
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    clip-path: polygon(0 0, 100% 0, 100% 35%, 0 35%);
  }

  .hero-title .glitch::before {
    color: var(--red);
    animation: glitch-top 4s infinite linear;
    transform: translateX(-3px);
  }

  .hero-title .glitch::after {
    color: rgba(100, 200, 255, 0.6);
    clip-path: polygon(0 65%, 100% 65%, 100% 100%, 0 100%);
    animation: glitch-bot 4s infinite linear;
    transform: translateX(3px);
  }

  @keyframes glitch-top {
    0%, 90%, 100% { transform: translateX(0);   opacity: 0; }
    92%           { transform: translateX(-4px); opacity: 1; }
    94%           { transform: translateX(4px);  opacity: 1; }
    96%           { transform: translateX(0);    opacity: 0; }
  }

  @keyframes glitch-bot {
    0%, 90%, 100% { transform: translateX(0);   opacity: 0; }
    91%           { transform: translateX(5px);  opacity: 1; }
    93%           { transform: translateX(-5px); opacity: 1; }
    95%           { transform: translateX(0);    opacity: 0; }
  }

  .hero-sub {
    font-size: 0.75rem;
    color: var(--white-dim);
    line-height: 1.7;
    margin-top: 1.5rem;
    max-width: 22rem;
  }

  .hero-side.left .hero-sub { margin-left: auto; }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    margin-top: 2.5rem;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--white);
    text-decoration: none;
    border-bottom: 1px solid var(--border-red);
    padding-bottom: 0.4rem;
    transition: color 0.2s, border-color 0.2s;
  }

  .hero-cta:hover { color: var(--red); border-color: var(--red); }
  .hero-cta svg   { width: 14px; height: 14px; }

  .hero-bg-text {
    position: absolute;
    font-family: var(--bebas);
    font-size: 22vw;
    line-height: 1;
    letter-spacing: -0.04em;
    color: rgba(240, 237, 232, 0.018);
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
  }

  .hero-side.left .hero-bg-text  { right: 2vw; bottom: -1vw; }
  .hero-side.right .hero-bg-text { left: -2vw;  bottom: -1vw; }

  .scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--white-dim);
    z-index: 20;
  }

  .scroll-line {
    width: 1px; height: 3rem;
    background: linear-gradient(to bottom, var(--red), transparent);
    animation: scroll-drop 1.8s ease-in-out infinite;
  }

  @keyframes scroll-drop {
    0%   { transform: scaleY(0); transform-origin: top;    opacity: 1; }
    50%  { transform: scaleY(1); transform-origin: top;    opacity: 1; }
    51%  { transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; opacity: 0; }
  }
</style>

<script>
  const waveformEl = document.getElementById('waveform');
  if (waveformEl) {
    for (let i = 0; i < 60; i++) {
      const bar = document.createElement('div');
      bar.className = 'wave-bar';
      const minH = 0.1 + Math.random() * 0.3;
      const maxH = minH + 0.3 + Math.random() * 0.5;
      bar.style.setProperty('--min', String(minH));
      bar.style.setProperty('--max', String(maxH));
      bar.style.animationDelay    = (Math.random() * 1.2) + 's';
      bar.style.animationDuration = (0.6 + Math.random() * 0.8) + 's';
      waveformEl.appendChild(bar);
    }
  }
</script>