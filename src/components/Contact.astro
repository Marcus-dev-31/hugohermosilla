<section class="contact" id="contacto">
  <div class="reveal">
    <div class="section-label">Contacto</div>
    <h2 class="contact-cta">
      <em>Hablemos de</em>
      TU <span class="red">PRÓXIMO</span><br>PROYECTO
    </h2>
    <a href="https://wa.me/541100000000" class="contact-btn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
      Escribir por WhatsApp
    </a>
  </div>

  <div class="contact-info reveal reveal-delay-2">
    <div class="contact-row">
      <div class="contact-row-label">Correo</div>
      <div class="contact-row-value">hugo@djhugo.com</div>
    </div>
    <div class="contact-row">
      <div class="contact-row-label">Instagram</div>
      <div class="contact-row-value">@djhugo</div>
    </div>
    <div class="contact-row">
      <div class="contact-row-label">SoundCloud</div>
      <div class="contact-row-value">soundcloud.com/djhugo</div>
    </div>
    <div class="contact-row">
      <div class="contact-row-label">Zona</div>
      <div class="contact-row-value">Buenos Aires — AR</div>
    </div>
  </div>
</section>

<footer>
  <div class="footer-logo"><span>.</span>HUGO</div>
  <div class="footer-copy">© 2025 — Todos los derechos reservados</div>
  <div class="footer-links">
    <a href="#">Instagram</a>
    <a href="#">SoundCloud</a>
    <a href="#">YouTube</a>
  </div>
</footer>

<style>
  .section-label {
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .section-label::after {
    content: '';
    flex: 1;
    max-width: 4rem;
    height: 1px;
    background: var(--red-dim);
  }

  .contact {
    background: var(--black);
    border-top: 1px solid var(--border);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .contact-cta {
    font-family: var(--bebas);
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.92;
    letter-spacing: 0.02em;
  }

  .contact-cta em {
    display: block;
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.42em;
    color: var(--white-dim);
    letter-spacing: 0.04em;
    margin-bottom: 0.5rem;
  }

  .contact-cta .red { color: var(--red); }

  .contact-btn {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    margin-top: 2.5rem;
    background: var(--red);
    color: var(--white);
    text-decoration: none;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 1rem 2rem;
    position: relative;
    overflow: hidden;
    transition: background 0.25s;
  }

  .contact-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.1);
    transform: translateX(-101%);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .contact-btn:hover::before { transform: translateX(0); }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-row {
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1.5rem;
    gap: 1.5rem;
  }

  .contact-row:last-child { border-bottom: none; }

  .contact-row-label {
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--white-dim);
    min-width: 5rem;
  }

  .contact-row-value {
    font-family: var(--bebas);
    font-size: 1.1rem;
    letter-spacing: 0.08em;
    color: var(--white);
  }

  footer {
    padding: 2rem 3rem;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--black);
  }

  .footer-logo {
    font-family: var(--bebas);
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    color: var(--white-dim);
  }

  .footer-logo span { color: var(--red); }

  .footer-copy {
    font-size: 0.62rem;
    color: var(--white-dim);
    letter-spacing: 0.1em;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--white-dim);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--red); }
</style>

<script>
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) e.target.classList.add('visible');
    });
  }, { threshold: 0.12 });
  reveals.forEach(el => observer.observe(el));
</script>